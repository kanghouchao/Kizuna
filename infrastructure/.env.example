# このプロジェクト用サンプル環境変数（Spring Boot / Java 向け）
# - このファイルに実際のシークレットやパスワードを直接記載しないでください。機密情報は `.env` に配置し、CI やシークレットマネージャーで管理してください。
# - 設定は `backend/src/main/resources/application.yml` と `infrastructure/<環境>/docker-compose.yml` に基づいています（サービス名: database, cache, storage, backend, frontend）。
# - 環境変数の接頭辞は「その設定を実際に消費するプロダクト名」に揃えています
#   （PostgreSQL=POSTGRES_ / MinIO=MINIO_ / Redis=REDIS_ / HikariCP=HIKARI_ / Lettuce=LETTUCE_ / Spring=SPRING_ / アプリ自身=APP_）。
#   1 つの値に 1 つの名前しか持たせません（旧 DB_* と POSTGRES_*、旧 UPLOAD_S3_* と MINIO_ROOT_* の二重定義は廃止済み）。

# Application
APP_NAME=Kizuna
APP_DOMAIN=kizuna.jp

# JWT
APP_JWT_SECRET=replace-with-a-secure-random-value

# -----------------------------
# Database (PostgreSQL)
# docker-compose のサービス名 `database` をホスト名として使用します。
# database コンテナ（postgres イメージ）と backend の双方がこの同じ変数を参照します。
# 例 JDBC URL: jdbc:postgresql://<host>:<port>/<database>
POSTGRES_HOST=database
POSTGRES_PORT=5432
POSTGRES_DB=kizuna
POSTGRES_USER=kizuna
POSTGRES_PASSWORD=changeme
# DB SSL/証明書: possible values: disable, allow, prefer, require, verify-ca, verify-full
# docker-compose の database サービス（postgres イメージ既定）は SSL 無効のため、development /
# release とも disable / false でなければ接続できない。外部マネージド DB（RDS 等）へ向ける場合のみ
# require 以上に変更する。POSTGRES_SSL は Hikari の data-source-properties.ssl に渡り、true だと
# POSTGRES_SSLMODE の値に関わらず SSL が必須になる点に注意。
POSTGRES_SSLMODE=disable
POSTGRES_SSL=false

# HikariCP（接続プール）チューニング（任意、デフォルトは application.yml に設定）
HIKARI_MINIMUM_IDLE=2
HIKARI_MAXIMUM_POOL_SIZE=10
HIKARI_IDLE_TIMEOUT=600000
HIKARI_MAX_LIFETIME=1800000
HIKARI_CONNECTION_TIMEOUT=30000
HIKARI_LEAK_DETECTION_THRESHOLD=2000

# -----------------------------
# Liquibase
# 実行コンテキスト。デモデータ（店舗 2 件と店長・スタッフ）の changeSet は contextFilter: demo で
# 隔離してあり、この変数の値に demo が含まれるときだけ投入される。コンテキスト未指定の changeSet
# （スキーマ本体と必須シード）はどの値でも常に適用される。
# このファイルは development / release の両方へコピーされるため、ここでは既定値を持たせない。
# 空のままなら compose 側の環境別既定（development=demo / release=production）が効く。
# 明示的に上書きしたいときだけ demo または production を書くこと。
LIQUIBASE_CONTEXTS=
# 初期 HQ 管理者（admin@kizuna.test）のパスワード bcrypt ハッシュ。
# 本番では必ず自前の値を設定すること。開発・E2E では application.yml の既定（平文 pass）で足りる。
#
# ⚠️ これは「初回デプロイ時の初期パスワード」専用。Liquibase はパラメータ展開後の内容で
#    checksum を計算するため、一度適用した後にこの値を変えると次回起動時に
#    「Validation Failed: changesets check sum」で起動不能になる（実測確認済み）。
#    運用後のパスワード変更はアプリの機能で行い、この変数は初回の値のまま据え置くこと。
#
# ⚠️ この変数は compose の environment に「裸名」で列挙されている。裸名の変数は
#    「.env に無い」なら変数自体がコンテナに存在せず application.yml の既定値が効くが、
#    「.env にあって空」だと空文字がそのまま渡り、既定値を打ち消す（Spring の ${VAR:既定} は
#    未定義のときしか既定を使わない）。空ハッシュで管理者が播種されログイン不能になるため、
#    値を入れないならこの行はコメントアウトのままにすること。
#INITIAL_ADMIN_PASSWORD_HASH=
# デモユーザー（田中花子・山田次郎）のパスワードハッシュ。demo コンテキスト専用。
# 同じ理由で、値を入れないならコメントアウトのままにすること。
#DEMO_USER_PASSWORD_HASH=

# -----------------------------
# JPA / Hibernate
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true

# -----------------------------
# Redis
# docker-compose の cache サービスを利用する場合、ホスト名は `cache` になります。
REDIS_HOST=cache
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DATABASE=0

# Redis 接続/クライアント設定
REDIS_SSL=false
REDIS_TIMEOUT=2000
REDIS_CLIENT_TYPE=lettuce

# Lettuce（Redis クライアント）プール設定
LETTUCE_POOL_MAX_ACTIVE=8
LETTUCE_POOL_MAX_IDLE=8
LETTUCE_POOL_MIN_IDLE=0
LETTUCE_POOL_MAX_WAIT=2000

# Spring Cache（Redis バックエンド）設定
SPRING_CACHE_TTL_MS=600000
SPRING_CACHE_NULL_VALUES=false
SPRING_CACHE_USE_KEY_PREFIX=true
SPRING_CACHE_KEY_PREFIX=kizuna:cache:


# -----------------------------
# Server
# 注意：リポジトリ内の `application.yml` のデフォルトポートは 8080 ですが、docker-compose/Traefik の設定ではバックエンドがロードバランサ用に 8000 を使用しています。実際のイメージ／デプロイに合わせて選択してください。
SERVER_PORT=8080

# -----------------------------
# Mail (Spring Mail)
# DB のシステム設定（t_system_configs の smtp_*）が未設定のときのフォールバック先。
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your@email.example
SPRING_MAIL_PASSWORD=changeme
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# -----------------------------
# フロントエンドが参照する内部サービスの URL
# バックエンドが実際にリッスンしているポートに合わせて調整してください（例: http://backend:8080 や http://backend:8000）。
STORE_LOOKUP_API_URL=http://backend:8080/platform/stores/lookup
STORE_CONFIG_API_URL=http://backend:8080/store/config/public
NEXT_PUBLIC_PLATFORM_DOMAIN=kizuna.test

# -----------------------------
# ファイルアップロード（アプリ側のポリシー）
APP_UPLOAD_URL_PREFIX=/static/uploads/
APP_UPLOAD_MAX_FILE_SIZE=10485760

# オブジェクトストレージ (MinIO)
# エンドポイントは docker-compose のサービス名 `storage` をホスト名として使用します。
MINIO_ENDPOINT=http://storage:9000
# 実バケット名（アプリ起動時に自動作成し public-read ポリシーを付与する）
MINIO_BUCKET=uploads
# MinIO の root アカウント。storage コンテナと backend の双方がこの同じ変数を参照するため、
# 設定元はここだけになる。MINIO_ROOT_PASSWORD は十分な長さの値を指定すること。
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme

# -----------------------------
# 使用方法：
# 1) このファイルを `.env` にコピーし、`changeme` やプレースホルダを実際のシークレットに置き換えてください。
# 2) CI やコンテナオーケストレーション環境ではシークレットマネージャーを使用し、実際の鍵をリポジトリにコミットしないでください。
